{
  "rootDir": "..",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec\\.ts$",
  "transform": {
    "^.+\\.(t|j)s$": [
      "ts-jest",
      {
        "tsconfig": "<rootDir>/tsconfig.json",
        "isolatedModules": true
      }
    ]
  },
  "moduleFileExtensions": ["js", "json", "ts"],
  "setupFiles": ["<rootDir>/test/setup.ts"],
  "testTimeout": 30000,
  "maxWorkers": 1
}
