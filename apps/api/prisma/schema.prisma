generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Lead {
  id            String   @id @default(cuid())
  name          String
  businessEmail String
  country       String
  message       String?
  createdAt     DateTime @default(now())

  @@index([businessEmail])
  @@index([createdAt])
}
