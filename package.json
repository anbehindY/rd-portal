{
  "name": "rd-portal",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "prisma": "pnpm --filter @rd-portal/api exec prisma",
    "db:migrate": "pnpm --filter @rd-portal/api exec prisma migrate dev",
    "db:generate": "pnpm --filter @rd-portal/api exec prisma generate",
    "db:studio": "pnpm --filter @rd-portal/api exec prisma studio"
  },
  "devDependencies": {
    "turbo": "^2.1.3",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=20"
  }
}
